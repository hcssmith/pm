{
  "name": "Example Project",
  "source": "./src",
  "artifact_dir": "./output",
  "agent": {
    "steps": [
      "COPY --from=golang:1.25.7-alpine /usr/local/go/ /usr/local/go/",
      "ENV PATH=\"/usr/local/go/bin:${PATH}\""
    ],
    "instructions": "AGENTS.md"
  },
  "actions": {
    "build": {
      "type":"native",
      "description": "Native echo test",
      "steps": [
        "echo test",
        "ls"
      ],
      "artifacts": [
        "main.go"
      ]
    },
    "docker-build": {
      "type": "docker",
      "description": "Build Go binary",
      "image": "golang:1.25.7",
      "workdir": "/src",
      "steps": [
        "COPY go.mod ./",
        "RUN go mod download"
      ],
      "cache_volumes": {
        "build_cache":"/tmp/go-build",
        "mod_cache":"/tmp/go-mod"
      },
      "env": {
        "GOCACHE":"/tmp/go-build",
        "GOMODCACHE":"/tmp/go-mod"
      },
      "cmd":"go build -o app .",
      "artifacts": [
        "app"
      ]
    },
    "develop": {
      "type": "docker",
      "description": "Interactive Go dev shell",
      "image": "golang:1.25.7",
      "workdir": "/src",
      "steps": [
        "COPY go.mod ./",
        "RUN go mod download"
      ],
      "cache_volumes": {
        "build_cache": "/tmp/go-build",
        "mod_cache": "/tmp/go-mod"
      },
      "env": {
        "GOCACHE": "/tmp/go-build",
        "GOMODCACHE": "/tmp/go-mod"
      },
      "cmd": "bash",
      "interactive": true
    }
  }
}
